{
  "name": "pika",
  "displayName": "PIKA",
  "version": "0.1.0",
  "description": "PIKA – Design Spec to Code Workflow. Run map and implement commands from VS Code.",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      {
        "command": "pika.openMap",
        "title": "PIKA: Open Map Panel"
      },
      {
        "command": "pika.openImplement",
        "title": "PIKA: Open Implement Panel"
      },
      {
        "command": "pika.refreshSidebar",
        "title": "PIKA: Refresh Sidebar"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pika",
          "title": "PIKA",
          "icon": "$(circuit-board)"
        }
      ]
    },
    "views": {
      "pika": [
        {
          "id": "pika.sidebar",
          "name": "PIKA",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "pika.openMap",
          "when": "resourceFilename == DESIGN-SPEC.csv",
          "group": "pika"
        },
        {
          "command": "pika.openImplement",
          "when": "resourceFilename == DESIGN-SPEC.csv",
          "group": "pika"
        }
      ]
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "compile": "npm run build",
    "watch": "node scripts/build.mjs --watch",
    "typecheck": "tsc -p tsconfig.extension.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "test": "vitest run",
    "package": "npm run build && npm run typecheck"
  },
  "keywords": ["vscode", "extension", "react", "pika", "design-spec"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.1.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.4.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.110.0",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
