{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "react", "react-dom", "vitest/globals"],
    "rootDir": "."
  },
  "include": ["webview-ui/src/**/*.ts", "webview-ui/src/**/*.tsx", "tests/**/*.ts"]
}
