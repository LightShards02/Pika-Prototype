{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ImplementOutput",
  "description": "Implementer output for one batch: either manual-resolution-only or spec-keyed results with optional hybrid diff_plan.",
  "type": "object",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["manual_resolution_items"],
      "properties": {
        "manual_resolution_items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/manual_resolution_item" }
        }
      }
    },
    {
      "type": "object",
      "required": ["run_summary", "diff_plan"],
      "additionalProperties": false,
      "properties": {
        "run_summary": { "$ref": "#/$defs/run_summary" },
        "diff_plan": { "$ref": "#/$defs/diff_plan" }
      },
      "patternProperties": {
        "^[A-Za-z][0-9]+$": { "$ref": "#/$defs/spec_result" }
      }
    }
  ],
  "$defs": {
    "run_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["success", "partial", "failed", "blocked"] },
        "notes": { "type": "string" }
      }
    },
    "diff_plan": {
      "type": "array",
      "items": { "$ref": "#/$defs/diff_plan_item" }
    },
    "diff_plan_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diff_id",
        "diff_path",
        "touched_files",
        "owner_spec_id",
        "related_spec_ids",
        "file_path",
        "op"
      ],
      "properties": {
        "diff_id": { "type": "string", "minLength": 1 },
        "diff_path": { "type": "string", "minLength": 1 },
        "touched_files": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "verification_notes": { "type": "string" },
        "owner_spec_id": { "type": "string", "pattern": "^[A-Za-z][0-9]+$" },
        "related_spec_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[A-Za-z][0-9]+$" }
        },
        "file_path": { "type": "string", "minLength": 1 },
        "op": { "type": "string", "enum": ["create", "modify", "delete", "rename"] }
      }
    },
    "spec_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "diff_refs", "mapped_classes_functions", "mapped_test_cases"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "diff_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "mapped_classes_functions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "qualified_name", "file_path"],
            "properties": {
              "kind": { "type": "string", "enum": ["function", "class", "enum"] },
              "qualified_name": { "type": "string", "minLength": 1 },
              "file_path": { "type": "string", "minLength": 1 }
            }
          }
        },
        "mapped_test_cases": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["framework", "test_file", "test_case"],
            "properties": {
              "framework": { "type": "string", "minLength": 1 },
              "test_file": { "type": "string", "minLength": 1 },
              "test_case": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "manual_option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["option_id", "label", "effect"],
      "properties": {
        "option_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "effect": { "type": "string", "minLength": 1 }
      }
    },
    "manual_resolution_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "title", "question", "options", "required", "blocking_reason"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "question": { "type": "string", "minLength": 1 },
        "options": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/manual_option" } },
        "recommended_option_id": { "type": "string" },
        "required": { "type": "boolean", "const": true },
        "blocking_reason": { "type": "string", "minLength": 1 },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
