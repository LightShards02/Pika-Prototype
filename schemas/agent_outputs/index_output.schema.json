{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IndexOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mappings",
    "manual_resolution_items",
    "run_summary",
    "created_at"
  ],
  "properties": {
    "mappings": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Za-z][0-9]+$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "code_refs",
          "notes"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "mapped",
              "partial",
              "unmapped",
              "blocked"
            ]
          },
          "code_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "path",
                "symbol_name",
                "symbol_type"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "symbol_name": {
                  "type": "string",
                  "minLength": 1
                },
                "symbol_type": {
                  "type": "string",
                  "enum": [
                    "class",
                    "function",
                    "module",
                    "variable",
                    "other"
                  ]
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "manual_resolution_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "entity_type",
          "entity_id",
          "reason",
          "details",
          "created_at"
        ],
        "properties": {
          "command": {
            "type": "string",
            "const": "agent index"
          },
          "entity_type": {
            "type": "string",
            "enum": [
              "spec",
              "mapping",
              "code_reference"
            ]
          },
          "entity_id": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "details": {
            "type": "string",
            "minLength": 1
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "minLength": 1
          }
        }
      }
    },
    "run_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "status",
        "summary",
        "blocking_items",
        "storage_file"
      ],
      "properties": {
        "command": {
          "type": "string",
          "const": "agent index"
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "partial",
            "blocked",
            "failed"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "blocking_items": {
          "type": "integer",
          "minimum": 0
        },
        "storage_file": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "minLength": 1
    }
  }
}
