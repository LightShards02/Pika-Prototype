{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ImplementAnchorLinkerOutput",
  "description": "Global link plan output for implement planning.",
  "type": "object",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["manual_resolution_items"],
      "properties": {
        "manual_resolution_items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/manual_resolution_item" }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["contracts", "bindings"],
      "properties": {
        "contracts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["contract_id", "kind", "canonical_name", "shape"],
            "properties": {
              "contract_id": { "type": "string", "minLength": 1 },
              "kind": {
                "type": "string",
                "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"]
              },
              "canonical_name": { "type": "string", "minLength": 1 },
              "shape": { "type": "object" },
              "type_locations": { "type": "object" }
            }
          }
        },
        "bindings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["required_ref", "provided_ref", "contract_id", "confidence", "rationale"],
            "properties": {
              "required_ref": {
                "type": "object",
                "additionalProperties": false,
                "required": ["module_tag", "intent_local_id"],
                "properties": {
                  "module_tag": { "type": "string", "minLength": 1 },
                  "intent_local_id": { "type": "string", "minLength": 1 }
                }
              },
              "provided_ref": {
                "type": "object",
                "additionalProperties": false,
                "required": ["module_tag", "intent_local_id"],
                "properties": {
                  "module_tag": { "type": "string", "minLength": 1 },
                  "intent_local_id": { "type": "string", "minLength": 1 }
                }
              },
              "contract_id": { "type": "string", "minLength": 1 },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "rationale": { "type": "string", "minLength": 1 },
              "adapter_needed": { "type": "boolean" },
              "adapter_plan": { "type": "object" }
            }
          }
        },
        "integration_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["action_id", "type", "details"],
            "properties": {
              "action_id": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "enum": ["create_shared_contracts", "add_adapter", "add_di_wiring", "add_smoke_tests"] },
              "details": { "type": "object" }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "manual_option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["option_id", "label", "effect"],
      "properties": {
        "option_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "effect": { "type": "string", "minLength": 1 }
      }
    },
    "manual_resolution_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "title", "question", "options", "required", "blocking_reason"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "question": { "type": "string", "minLength": 1 },
        "options": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/manual_option" } },
        "recommended_option_id": { "type": "string" },
        "required": { "type": "boolean", "const": true },
        "blocking_reason": { "type": "string", "minLength": 1 },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
