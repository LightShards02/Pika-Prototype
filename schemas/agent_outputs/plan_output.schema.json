{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanOutput",
  "description": "Project Designer (agent plan) output. The agent writes the design spec draft (SADS-compatible CSV) to a file in agent_artifacts_dir and returns its path. When manual_resolution_items is non-empty, output must contain ONLY manual_resolution_items (blocking rule).",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["manual_resolution_items", "run_summary", "created_at"],
      "properties": {
        "manual_resolution_items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/manual_resolution_item_plan" }
        },
        "run_summary": { "$ref": "#/$defs/run_summary_plan" },
        "created_at": { "type": "string", "format": "date-time", "minLength": 1 }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["proposed_sads_outline_path", "manual_resolution_items", "run_summary", "created_at"],
      "properties": {
        "milestones": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "title", "description"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "dependencies": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "proposed_sads_outline_path": {
          "type": "string",
          "minLength": 1,
          "description": "Path to SADS-compatible CSV file written by the agent in agent_artifacts_dir. Contains spec_id, title, requirement, acceptance_criteria, status per csv_contracts.md."
        },
        "manual_resolution_items": { "type": "array", "maxItems": 0 },
        "run_summary": { "$ref": "#/$defs/run_summary_plan" },
        "created_at": { "type": "string", "format": "date-time", "minLength": 1 }
      }
    }
  ],
  "$defs": {
    "manual_resolution_item_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "entity_type", "entity_id", "reason", "details", "created_at"],
      "properties": {
        "command": { "type": "string", "const": "agent plan" },
        "entity_type": { "type": "string", "enum": ["requirement", "milestone", "sads_outline"] },
        "entity_id": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "details": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date-time", "minLength": 1 }
      }
    },
    "run_summary_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "status", "summary", "blocking_items", "storage_file"],
      "properties": {
        "command": { "type": "string", "const": "agent plan" },
        "status": { "type": "string", "enum": ["success", "partial", "blocked", "failed"] },
        "summary": { "type": "string", "minLength": 1 },
        "blocking_items": { "type": "integer", "minimum": 0 },
        "storage_file": { "type": "string", "minLength": 1 }
      }
    }
  }
}
