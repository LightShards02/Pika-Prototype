{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PikaConfig",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "project",
    "prompts",
    "schemas",
    "commands",
    "id_generation",
    "csv_contracts",
    "logging"
  ],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "root_dir", "state"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "root_dir": { "type": "string", "minLength": 1 },
        "control_vocab_path": {
          "type": "string",
          "minLength": 1,
          "description": "Path to per-project controlled vocabulary YAML (relative to project root). Injected into all LLM prompts. Optional."
        },
        "state": {
          "type": "object",
          "additionalProperties": false,
          "required": ["design_spec_path", "id_registry_path", "sads_id_mapping_path"],
          "properties": {
            "design_spec_path": { "type": "string", "minLength": 1, "description": "Canonical design spec path. Format copies here after writing. Map, implement, review, resolve_plan read from here by default." },
            "id_registry_path": { "type": "string", "minLength": 1, "description": "Path for id_registry.json. Commands write to out/state first, then copy here." },
            "sads_id_mapping_path": { "type": "string", "minLength": 1, "description": "Path for sads_id_mapping.json. Format writes to out/state first, then copy here." }
          }
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "description": "Deprecated. Use commands.<cmd>.inputs as single source of truth.",
      "properties": {
        "srs_path": { "type": "string", "minLength": 1 },
        "design_spec_path": { "type": "string", "minLength": 1 },
        "codebase_dir": { "type": "string", "minLength": 1, "description": "Path to codebase/source directory for plan, map, implement. Used as fallback dir for project context file. Absolute or relative to project root." },
        "project_context_filename": { "type": "string", "minLength": 1, "description": "Filename for project context in project root (e.g. PROJECT_CONTEXT.md). Used when --project-context not provided." },
        "extra_prompt_filename": { "type": "string", "minLength": 1, "description": "Filename for extra prompt in project root (e.g. EXTRA-PROMPT.md). Used by map command when --extra-prompt not provided. Optional; when omitted in both config and CLI, no file is looked for and extra section is empty." },
        "issue_tracking_path": { "type": "string", "minLength": 1 },
        "allowed_extensions": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "enum": [".csv", ".xlsx"] },
          "allOf": [
            { "contains": { "const": ".csv" } },
            { "contains": { "const": ".xlsx" } }
          ]
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "description": "Deprecated. Use commands.<cmd>.outputs as single source of truth.",
      "properties": {
        "root_dir": { "$ref": "#/$defs/output_target" },
        "backups_dir": { "$ref": "#/$defs/output_target" },
        "agent_runs_dir": { "$ref": "#/$defs/output_target" },
        "agent_artifacts_dir": { "$ref": "#/$defs/output_target" },
        "logs_dir": { "$ref": "#/$defs/output_target" },
        "agent_view_csv": { "$ref": "#/$defs/output_target" },
        "intermediate_map_dir": { "$ref": "#/$defs/output_target" },
        "agent_input_codebase_content_dir": { "$ref": "#/$defs/output_target" }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["stub", "api", "local"],
          "description": "Agent provider: stub (mock), api (remote HTTP chat completions), or local (CLI subprocess e.g. Codex)."
        },
        "schema_validation_retries": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of retries when agent output fails schema validation. 0 = no retries."
        },
        "stream_output": {
          "type": "boolean",
          "description": "If true, stream agent output to terminal and show heartbeat when agent runs (api, local)."
        },
        "local_command": {
          "type": "string",
          "minLength": 1,
          "description": "Executable name or path when provider is local. Default: codex."
        },
        "local_exec_timeout_sec": {
          "type": "integer",
          "minimum": 1,
          "description": "Timeout (seconds) for local provider subprocess executions. Overrides pika local.exec_timeout_sec for this workspace."
        },
        "local_model": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            {
              "type": "object",
              "additionalProperties": { "type": "string", "minLength": 1 },
              "description": "Per-prompt model ID. Keys: prompt_name (map_spec_to_code, implement_unified_planner, implement_from_specs) or default."
            }
          ],
          "description": "Codex model ID when provider is local. String = same for all prompts. Object = per-prompt overrides. Overrides pika local.model."
        },
        "api_key_env": {
          "type": "string",
          "minLength": 1,
          "description": "Environment variable name for API Bearer token when provider is api. Default from pika config."
        },
        "api_url": {
          "type": "string",
          "minLength": 1,
          "description": "Chat completions API URL when provider is api. Default from pika config."
        },
        "api_model": {
          "type": "string",
          "minLength": 1,
          "description": "Model ID when provider is api. Default from pika config."
        },
        "reasoning_effort": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["low", "medium", "high", "xhigh"],
            "description": "Codex model_reasoning_effort: low, medium, high, or xhigh."
          },
          "description": "Per-prompt reasoning effort for Codex (provider=local). Keys: prompt_name (e.g. map_spec_to_code, implement_unified_planner, implement_from_specs) or 'default'. Values: low, medium, high, xhigh. Map and planner default to medium; implementer to high."
        }
      }
    },
    "prompts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt_file"],
      "properties": { "prompt_file": { "type": "string", "minLength": 1 } }
    },
    "schemas": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "map_output",
        "implement_output",
        "resolve_plan_map_output",
        "resolve_plan_output"
      ],
      "properties": {
        "plan_output": { "type": "string", "minLength": 1 },
        "map_output": { "type": "string", "minLength": 1 },
        "implement_output": { "type": "string", "minLength": 1 },
        "resolve_plan_map_output": { "type": "string", "minLength": 1 },
        "resolve_plan_output": { "type": "string", "minLength": 1 }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "map", "implement", "resolve_plan"],
      "properties": {
        "plan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "prompt_name"],
          "properties": {
            "enabled": { "type": "boolean" },
            "prompt_name": {
              "type": "string",
              "minLength": 1,
              "description": "Deprecated alias of implement.implementer.prompt_name."
            },
            "unified_planner_prompt_name": {
              "type": "string",
              "minLength": 1,
              "description": "Deprecated alias of implement.unified_planner.prompt_name."
            },
            "inputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "srs_path": { "type": "string", "minLength": 1 },
                "project_context_filename": { "type": "string", "minLength": 1 }
              }
            },
            "outputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "root_dir": { "$ref": "#/$defs/output_target" },
                "backups_dir": { "$ref": "#/$defs/output_target" },
                "agent_runs_dir": { "$ref": "#/$defs/output_target" },
                "agent_artifacts_dir": { "$ref": "#/$defs/output_target" },
                "logs_dir": { "$ref": "#/$defs/output_target" }
              }
            },
            "schemas": {
              "type": "object",
              "additionalProperties": false,
              "properties": { "plan_output": { "type": "string", "minLength": 1 } }
            }
          }
        },
        "format": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "deterministic", "copy_before_write", "outputs"],
          "properties": {
            "enabled": { "type": "boolean" },
            "deterministic": { "type": "boolean", "const": true },
            "copy_before_write": { "type": "boolean", "const": true },
            "inputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "design_spec_path": { "type": "string", "minLength": 1, "description": "Source path for format. CLI --design-spec overrides; otherwise this value is used. No further fallback." }
              }
            },
            "outputs": {
              "type": "object",
              "additionalProperties": false,
              "required": ["design_spec_path"],
              "properties": {
                "design_spec_path": { "$ref": "#/$defs/output_target", "description": "Path where format writes. After writing, format copies to project.state.design_spec_path." },
                "backups_dir": { "$ref": "#/$defs/output_target", "description": "Directory for backups before overwrite when copy_before_write." }
              }
            },
            "sensitive_keywords": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "required": ["keywords"],
                "properties": {
                  "keywords": { "type": "array", "items": { "type": "string" } },
                  "case_sensitive": { "type": "boolean", "default": false }
                }
              },
              "description": "Replacement -> {keywords: [...], case_sensitive?: bool}. keywords required; case_sensitive optional (default false). Whole-word match."
            }
          }
        },
        "review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "prompt_name"],
          "properties": {
            "enabled": { "type": "boolean" },
            "prompt_name": { "type": "string", "minLength": 1 },
            "inputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "design_spec_path": { "type": "string", "minLength": 1 },
                "srs_path": { "type": "string", "minLength": 1 },
                "project_context_filename": { "type": "string", "minLength": 1 }
              }
            },
            "outputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "root_dir": { "$ref": "#/$defs/output_target" },
                "backups_dir": { "$ref": "#/$defs/output_target" },
                "agent_runs_dir": { "$ref": "#/$defs/output_target" },
                "agent_artifacts_dir": { "$ref": "#/$defs/output_target" },
                "logs_dir": { "$ref": "#/$defs/output_target" }
              }
            },
            "schemas": {
              "type": "object",
              "additionalProperties": false,
              "properties": { "review_output": { "type": "string", "minLength": 1 } }
            }
          }
        },
        "map": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "prompt_name"],
          "properties": {
            "enabled": { "type": "boolean" },
            "prompt_name": { "type": "string", "minLength": 1 },
            "inputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "design_spec_path": { "type": "string", "minLength": 1 },
                "codebase_dir": { "type": "string", "minLength": 1 },
                "project_context_filename": { "type": "string", "minLength": 1 },
                "extra_prompt_filename": { "type": "string", "minLength": 1 }
              }
            },
            "outputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "root_dir": { "$ref": "#/$defs/output_target" },
                "backups_dir": { "$ref": "#/$defs/output_target" },
                "agent_runs_dir": { "$ref": "#/$defs/output_target" },
                "agent_artifacts_dir": { "$ref": "#/$defs/output_target" },
                "logs_dir": { "$ref": "#/$defs/output_target" },
                "agent_view_csv": { "$ref": "#/$defs/output_target" },
                "intermediate_map_dir": { "$ref": "#/$defs/output_target" },
                "agent_input_codebase_content_dir": { "$ref": "#/$defs/output_target" }
              }
            },
            "schemas": {
              "type": "object",
              "additionalProperties": false,
              "properties": { "map_output": { "type": "string", "minLength": 1 } }
            },
            "skip_mapped": {
              "type": "boolean",
              "description": "Skip map_status=mapped on re-runs. Default true."
            },
            "max_acceptance_chars": {
              "type": "integer",
              "minimum": 0,
              "description": "Truncate acceptance_criteria at invocation (0 = unlimited)."
            },
            "max_specs_per_subunit": {
              "type": "integer",
              "minimum": 1,
              "description": "Max rows per subunit agent call. Larger subunits are split into consecutive sub-batches."
            },
            "min_remapping_confidence_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Re-map 'mapped' rows whose max confidence falls below this threshold. Default 0.0 (disabled)."
            },
            "max_problem_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Inject into prompt: agents must only populate problems when confidence OR consistency_score < threshold. Default 1.0."
            }
          }
        },
        "implement": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "prompt_name": { "type": "string", "minLength": 1 },
            "inputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "design_spec_path": { "type": "string", "minLength": 1 },
                "codebase_dir": { "type": "string", "minLength": 1 },
                "project_context_filename": { "type": "string", "minLength": 1 },
                "issue_tracker_path": { "type": "string", "minLength": 1 }
              }
            },
            "outputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "root_dir": { "$ref": "#/$defs/output_target" },
                "backups_dir": { "$ref": "#/$defs/output_target" },
                "agent_runs_dir": { "$ref": "#/$defs/output_target" },
                "agent_artifacts_dir": { "$ref": "#/$defs/output_target" },
                "logs_dir": { "$ref": "#/$defs/output_target" },
                "agent_input_codebase_content_dir": { "$ref": "#/$defs/output_target" }
              }
            },
            "schemas": {
              "type": "object",
              "additionalProperties": false,
              "properties": { "implement_output": { "type": "string", "minLength": 1 } }
            },
            "unified_planner": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "prompt_name": { "type": "string", "minLength": 1 },
                "disallowed_link_kinds_by_required_role": {
                  "$ref": "#/properties/commands/properties/implement/properties/disallowed_link_kinds_by_required_role"
                },
                "leaf_dependency_roles": {
                  "$ref": "#/properties/commands/properties/implement/properties/leaf_dependency_roles"
                },
                "leaf_dependency_policy": {
                  "$ref": "#/properties/commands/properties/implement/properties/leaf_dependency_policy"
                },
                "contract_kind_definitions": {
                  "$ref": "#/properties/commands/properties/implement/properties/contract_kind_definitions"
                },
                "type_shape_match": {
                  "$ref": "#/properties/commands/properties/implement/properties/type_shape_match"
                },
                "min_confidence_threshold": {
                  "$ref": "#/properties/commands/properties/implement/properties/min_confidence_threshold"
                }
              }
            },
            "implementer": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "prompt_name": { "type": "string", "minLength": 1 }
              }
            },
            "workset_schema_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "module_catalog_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "planner_path_contract_prep": { "$ref": "#/$defs/implement_step_toggle" },
            "planner_semantic_validation": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "semantic_validation_retries": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Step-level retries for planner semantic validation."
                }
              }
            },
            "planner_manual_resolution_gate": { "$ref": "#/$defs/implement_step_toggle" },
            "spec_issue_escalation": { "$ref": "#/$defs/implement_step_toggle" },
            "unified_plan_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "contract_field_consistency_validation": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "field_match_score_threshold": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Step-level normalized similarity threshold (0..1) for contract/spec high-match pairs."
                },
                "field_match_distance_threshold": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Deprecated alias of field_match_score_threshold for this step."
                }
              }
            },
            "required_field_coverage_validation": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "providerless_contract_allowlist": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Contract IDs intentionally exempt from the providerless manual-block check (always skipped)."
                }
              }
            },
            "batch_plan_construction": { "$ref": "#/$defs/implement_step_toggle" },
            "batch_plan_dependency_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "batch_brief_build": { "$ref": "#/$defs/implement_step_toggle" },
            "batch_brief_scope_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "dependency_context_edge_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "batch_runtime_path_contract_prep": { "$ref": "#/$defs/implement_step_toggle" },
            "implement_semantic_validation": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "semantic_validation_retries": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Step-level retries for implement output semantic validation."
                }
              }
            },
            "implement_output_structure_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "patch_constraints_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "verification_command_resolution": { "$ref": "#/$defs/implement_step_toggle" },
            "patch_normalization": { "$ref": "#/$defs/implement_step_toggle" },
            "patch_apply_gate": { "$ref": "#/$defs/implement_step_toggle" },
            "contract_schema_conformance_check": { "$ref": "#/$defs/implement_step_toggle" },
            "verification_execution": { "$ref": "#/$defs/implement_step_toggle" },
            "type_placement_path": {
              "type": "string",
              "minLength": 1,
              "description": "Path prefix for cross-module shared type locations."
            },
            "allowed_module_roles": {
              "type": "array",
              "items": { "type": "string", "enum": ["frontend", "api", "domain", "infra", "shared", "cli", "worker"] },
              "description": "Allowed module_role values for implement validation."
            },
            "disallowed_link_kinds_by_required_role": {
              "type": "object",
              "additionalProperties": false,
              "description": "Role-based contract kinds disallowed on required bindings during implement link-plan validation.",
              "properties": {
                "frontend": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"] }
                },
                "api": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"] }
                },
                "domain": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"] }
                },
                "infra": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"] }
                },
                "shared": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"] }
                },
                "cli": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"] }
                },
                "worker": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"] }
                }
              }
            },
            "leaf_dependency_roles": {
              "type": "array",
              "items": { "type": "string", "enum": ["frontend", "api", "domain", "infra", "shared", "cli", "worker"] },
              "description": "Module roles treated as leaf dependencies. For these roles, required_intents are auto-dropped during normalization."
            },
            "leaf_dependency_policy": {
              "type": "object",
              "additionalProperties": false,
              "description": "Deterministic policy for leaf dependency enforcement.",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": ["auto_drop"],
                  "description": "Leaf dependency handling mode. Currently only auto_drop is supported."
                },
                "track_external_dependencies": {
                  "type": "boolean",
                  "description": "When true, dropped leaf required_intents are preserved as declared_external_dependencies."
                }
              }
            },
            "contract_kind_definitions": {
              "type": "object",
              "additionalProperties": false,
              "description": "Canonical semantic definitions for contract kinds, injected into planner prompts.",
              "properties": {
                "api_endpoint": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["definition"],
                  "properties": { "definition": { "type": "string", "minLength": 1 } }
                },
                "service_interface": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["definition"],
                  "properties": { "definition": { "type": "string", "minLength": 1 } }
                },
                "event_topic": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["definition"],
                  "properties": { "definition": { "type": "string", "minLength": 1 } }
                },
                "db_table": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["definition"],
                  "properties": { "definition": { "type": "string", "minLength": 1 } }
                },
                "file_format": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["definition"],
                  "properties": { "definition": { "type": "string", "minLength": 1 } }
                },
                "external_api": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["definition"],
                  "properties": { "definition": { "type": "string", "minLength": 1 } }
                },
                "test_suite": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["definition"],
                  "properties": { "definition": { "type": "string", "minLength": 1 } }
                }
              }
            },
            "type_shape_match": {
              "type": "object",
              "additionalProperties": false,
              "description": "Deterministic thresholds for normalized required->provided candidate scoring.",
              "properties": {
                "min_auto_bind_score": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Minimum top candidate score to mark auto_bind_candidate in normalized intent catalog."
                },
                "tie_margin": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Required score margin between top-1 and top-2 candidate for auto_bind_candidate."
                }
              }
            },
            "field_match_score_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Deprecated top-level alias of implement.contract_field_consistency_validation.field_match_score_threshold."
            },
            "field_match_distance_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Deprecated alias of field_match_score_threshold. Kept for backward compatibility."
            },
            "issue_tracker_path": {
              "type": "string",
              "minLength": 1,
              "description": "Path to implementation issue tracker CSV for verification failures."
            },
            "test_spec_path": {
              "type": "string",
              "minLength": 1,
              "description": "Path to test_spec CSV generated/updated by implement."
            },
            "verification_commands": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "description": "Commands run after patch application for batch verification."
            },
            "semantic_validation_retries": {
              "type": "integer",
              "minimum": 0,
              "description": "Deprecated top-level alias used as fallback for planner_semantic_validation.semantic_validation_retries and implement_semantic_validation.semantic_validation_retries."
            },
            "forbidden_paths": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "description": "Relative path prefixes disallowed for implement diffs."
            },
            "budgets": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "max_specs_per_batch": { "type": "integer", "minimum": 1 },
                "max_files": { "type": "integer", "minimum": 1 },
                "max_lines_changed": { "type": "integer", "minimum": 1 },
                "max_context_tokens": { "type": "integer", "minimum": 1 }
              }
            },
            "min_confidence_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "During batch briefs planning, items with confidence below this value are appended to manual_resolution_items and block downstream code generation until resolved. Project config overrides pika config (default 0.7). Set to 0 to disable."
            }
          }
        },
        "resolve_plan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "map_prompt_name", "resolve_prompt_name"],
          "properties": {
            "enabled": { "type": "boolean" },
            "inputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "design_spec_path": { "type": "string", "minLength": 1 },
                "issue_tracking_path": { "type": "string", "minLength": 1 }
              }
            },
            "outputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "root_dir": { "$ref": "#/$defs/output_target" },
                "backups_dir": { "$ref": "#/$defs/output_target" },
                "agent_runs_dir": { "$ref": "#/$defs/output_target" },
                "agent_artifacts_dir": { "$ref": "#/$defs/output_target" },
                "logs_dir": { "$ref": "#/$defs/output_target" }
              }
            },
            "schemas": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "resolve_plan_map_output": { "type": "string", "minLength": 1 },
                "resolve_plan_output": { "type": "string", "minLength": 1 }
              }
            },
            "map_prompt_name": { "type": "string", "minLength": 1 },
            "resolve_prompt_name": { "type": "string", "minLength": 1 }
          }
        },
        "refine": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "ambiguity_detector": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "prompt_name": { "type": "string", "minLength": 1 }
              }
            },
            "testability_auditor": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "prompt_name": { "type": "string", "minLength": 1 }
              }
            },
            "spec_editor": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "prompt_name": { "type": "string", "minLength": 1 }
              }
            },
            "decomposition": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "blocking": { "type": "boolean" },
                "similarity_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
                "variance_threshold": { "type": "number", "minimum": 0 }
              }
            },
            "inputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "design_spec_path": { "type": "string", "minLength": 1 },
                "project_context_filename": { "type": "string", "minLength": 1 }
              }
            },
            "outputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "root_dir": { "$ref": "#/$defs/output_target" },
                "design_spec_path": { "$ref": "#/$defs/output_target" },
                "agent_runs_dir": { "$ref": "#/$defs/output_target" }
              }
            }
          }
        }
      }
    },
    "id_generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spec", "issue", "collision_scope", "registry_path"],
      "properties": {
        "spec": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pattern"],
          "properties": { "pattern": { "type": "string", "const": "^[A-Za-z][0-9]+$" } }
        },
        "issue": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pattern"],
          "properties": { "pattern": { "type": "string", "const": "^[A-Za-z]{2}[0-9]+$" } }
        },
        "collision_scope": { "type": "string", "enum": ["per_type_numeric_suffix"] },
        "registry_path": { "type": "string", "minLength": 1, "const": "out/state/id_registry.json" }
      }
    },
    "csv_contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["design_spec", "issue_tracking"],
      "properties": {
        "design_spec": {
          "type": "object",
          "additionalProperties": false,
          "required": ["add_if_missing"],
          "properties": {
            "add_if_missing": {
              "type": "array",
              "minItems": 11,
              "maxItems": 11,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "spec_id",
                  "module_tag",
                  "subunit",
                  "mapped_code_symbols",
                  "mapped_confidence",
                  "mapped_consistency_score",
                  "mapped_problems",
                  "map_status",
                  "map_assumptions",
                  "mapped_at",
                  "map_run_id"
                ]
              },
              "allOf": [
                { "contains": { "const": "spec_id" } },
                { "contains": { "const": "module_tag" } },
                { "contains": { "const": "subunit" } },
                { "contains": { "const": "mapped_code_symbols" } },
                { "contains": { "const": "mapped_confidence" } },
                { "contains": { "const": "mapped_consistency_score" } },
                { "contains": { "const": "mapped_problems" } },
                { "contains": { "const": "map_status" } },
                { "contains": { "const": "map_assumptions" } },
                { "contains": { "const": "mapped_at" } },
                { "contains": { "const": "map_run_id" } }
              ]
            }
          }
        },
        "issue_tracking": {
          "type": "object",
          "additionalProperties": false,
          "required": ["add_if_missing"],
          "properties": {
            "add_if_missing": {
              "type": "array",
              "minItems": 6,
              "maxItems": 6,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "issue_id",
                  "author",
                  "mapped_spec_ids",
                  "issue_notes",
                  "follow_up_uncertainties",
                  "last_resolved_at"
                ]
              },
              "allOf": [
                { "contains": { "const": "issue_id" } },
                { "contains": { "const": "author" } },
                { "contains": { "const": "mapped_spec_ids" } },
                { "contains": { "const": "issue_notes" } },
                { "contains": { "const": "follow_up_uncertainties" } },
                { "contains": { "const": "last_resolved_at" } }
              ]
            }
          }
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "verbose_level", "json", "log_dir"],
      "properties": {
        "level": { "type": "string", "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"] },
        "verbose_level": { "type": "string", "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"] },
        "json": { "type": "boolean" },
        "log_dir": { "type": "string", "minLength": 1 }
      }
    },
    "codebase_transmission": {
      "type": "object",
      "additionalProperties": false,
      "description": "Controls how source files are included in prompts for API-based agents. Ignored when provider is local.",
      "properties": {
        "max_summary_chars": { "type": "integer", "minimum": 1000, "description": "Cap on total snapshot (AST + raw files combined). Default 200000." },
        "max_raw_files": { "type": "integer", "minimum": 1, "description": "For implement/resolve_plan: how many raw files to include. Default 10." },
        "max_raw_chars_per_file": { "type": "integer", "minimum": 100, "description": "Truncate raw files longer than this. Default 5000." },
        "include_extensions": { "type": "array", "items": { "type": "string" }, "description": "File extensions to include." },
        "exclude_patterns": { "type": "array", "items": { "type": "string" }, "description": "Glob patterns to exclude." },
        "depth_limit": { "type": "integer", "minimum": 1, "description": "Max directory depth from codebase root. Default 15." }
      }
    }
  },
  "$defs": {
    "implement_step_toggle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "output_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "no_overwrite"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "no_overwrite": { "type": "boolean" }
      }
    }
  }
}
