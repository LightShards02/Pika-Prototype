{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResolvePlanMapOutput",
  "description": "Resolution Organizer map phase (agent resolve_plan) output. When manual_resolution_items is non-empty, output must contain ONLY manual_resolution_items (blocking rule).",
  "type": "object",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["manual_resolution_items", "run_summary", "created_at"],
      "properties": {
        "manual_resolution_items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/manual_resolution_item_resolve" }
        },
        "run_summary": { "$ref": "#/$defs/run_summary_resolve" },
        "created_at": { "type": "string", "format": "date-time", "minLength": 1 }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["mappings", "manual_resolution_items", "run_summary", "created_at"],
      "properties": {
        "mappings": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "pattern": "^[A-Za-z]{2}[0-9]+$" },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["spec_ids", "notes"],
            "properties": {
              "spec_ids": {
                "type": "array",
                "items": { "type": "string", "pattern": "^[A-Za-z][0-9]+$" }
              },
              "notes": { "type": "string" }
            }
          }
        },
        "manual_resolution_items": { "type": "array", "maxItems": 0 },
        "run_summary": { "$ref": "#/$defs/run_summary_resolve" },
        "created_at": { "type": "string", "format": "date-time", "minLength": 1 }
      }
    }
  ],
  "$defs": {
    "manual_resolution_item_resolve": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "entity_type", "entity_id", "reason", "details", "created_at"],
      "properties": {
        "command": { "type": "string", "const": "agent resolve_plan" },
        "entity_type": { "type": "string", "enum": ["issue", "mapping"] },
        "entity_id": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "details": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date-time", "minLength": 1 }
      }
    },
    "run_summary_resolve": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "status", "summary", "blocking_items", "storage_file"],
      "properties": {
        "command": { "type": "string", "const": "agent resolve_plan" },
        "status": { "type": "string", "enum": ["success", "partial", "blocked", "failed"] },
        "summary": { "type": "string", "minLength": 1 },
        "blocking_items": { "type": "integer", "minimum": 0 },
        "storage_file": { "type": "string", "minLength": 1 }
      }
    }
  }
}
