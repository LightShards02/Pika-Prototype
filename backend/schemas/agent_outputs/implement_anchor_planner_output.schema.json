{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ImplementAnchorPlannerOutput",
  "description": "Anchor planner output for one module during implement planning.",
  "type": "object",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["manual_resolution_items"],
      "properties": {
        "manual_resolution_items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/manual_resolution_item" }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module_tag",
        "planned_anchors",
        "provided_intents",
        "required_intents"
      ],
      "properties": {
        "module_tag": { "type": "string", "minLength": 1 },
        "planned_anchors": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "anchor_kind",
              "anchor_materialization_kind",
              "planned_file_path",
              "spec_ids"
            ],
            "properties": {
              "anchor_kind": {
                "type": "string",
                "enum": ["new_symbol", "existing_symbol", "file_location", "boundary_file"]
              },
              "anchor_materialization_kind": {
                "type": "string",
                "enum": ["schema", "interface", "runtime_logic", "wiring", "test"]
              },
              "planned_file_path": { "type": "string", "minLength": 1 },
              "planned_symbol": { "type": "string" },
              "signature_hint": { "type": "string" },
              "spec_ids": {
                "type": "array",
                "items": { "type": "string", "pattern": "^[A-Za-z][0-9]+$" }
              }
            }
          }
        },
        "provided_intents": { "type": "array", "items": { "$ref": "#/$defs/intent" } },
        "required_intents": { "type": "array", "items": { "$ref": "#/$defs/intent" } },
        "declared_external_dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/external_dependency" }
        },
        "intra_module_dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["spec_id", "depends_on", "reason"],
            "properties": {
              "spec_id": { "type": "string", "pattern": "^[A-Za-z][0-9]+$" },
              "depends_on": {
                "type": "array",
                "items": { "type": "string", "pattern": "^[A-Za-z][0-9]+$" }
              },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "io_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type_name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type_name": { "type": "string", "minLength": 1 },
        "constraints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent_local_id",
        "kind",
        "capability_name",
        "description",
        "inputs",
        "outputs",
        "error_modes",
        "spec_ids",
        "confidence"
      ],
      "properties": {
        "intent_local_id": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"]
        },
        "capability_name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "inputs": { "type": "array", "items": { "$ref": "#/$defs/io_item" } },
        "outputs": { "type": "array", "items": { "$ref": "#/$defs/io_item" } },
        "error_modes": { "type": "array", "items": { "type": "string" } },
        "nonfunctional": { "type": "object" },
        "planned_anchor": { "type": "object" },
        "call_site_plan": { "type": "object" },
        "provider_constraints": { "type": "object" },
        "spec_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z][0-9]+$" }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "external_dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dependency_id",
        "source_intent_local_id",
        "kind",
        "capability_name",
        "description",
        "spec_ids",
        "confidence"
      ],
      "properties": {
        "dependency_id": { "type": "string", "minLength": 1 },
        "source_intent_local_id": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"]
        },
        "capability_name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "spec_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z][0-9]+$" }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "manual_option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["option_id", "label", "effect"],
      "properties": {
        "option_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "effect": { "type": "string", "minLength": 1 }
      }
    },
    "manual_resolution_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "title", "question", "options", "required", "blocking_reason"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "question": { "type": "string", "minLength": 1 },
        "options": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/manual_option" } },
        "recommended_option_id": { "type": "string" },
        "required": { "type": "boolean", "const": true },
        "blocking_reason": { "type": "string", "minLength": 1 },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
