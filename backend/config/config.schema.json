{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PikaConfig",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "project",
    "default_outputs",
    "commands",
    "id_generation",
    "logging"
  ],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "root_dir", "state"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "root_dir": { "type": "string", "minLength": 1 },
        "control_vocab_path": {
          "type": "string",
          "minLength": 1,
          "description": "Path to per-project controlled vocabulary YAML (relative to project root). Injected into all LLM prompts. Optional."
        },
        "state": {
          "type": "object",
          "additionalProperties": false,
          "required": ["design_spec_path", "id_registry_path", "sads_id_mapping_path"],
          "properties": {
            "design_spec_path": { "type": "string", "minLength": 1, "description": "Canonical design spec path. Format copies here after writing. Map, implement, review, resolve_plan read from here by default." },
            "id_registry_path": { "type": "string", "minLength": 1, "description": "Path for id_registry.json. Commands write to out/state first, then copy here." },
            "sads_id_mapping_path": { "type": "string", "minLength": 1, "description": "Path for sads_id_mapping.json. Format writes to out/state first, then copy here." }
          }
        }
      }
    },
    "default_outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["log_dir"],
      "properties": {
        "log_dir": {
          "type": "string",
          "minLength": 1,
          "description": "Run log directory (relative to project root or absolute). Same key as pika.yaml default_outputs.log_dir; overrides PIKA default when set."
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["stub", "local"],
          "description": "Agent provider: stub (mock) or local (Loca in-process LLM agent)."
        },
        "schema_validation_retries": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of retries when agent output fails schema validation. 0 = no retries."
        },
        "stream_output": {
          "type": "boolean",
          "description": "If true, stream agent output to terminal and show heartbeat when agent runs (local)."
        },
        "local_command": {
          "type": "string",
          "minLength": 1,
          "deprecated": true,
          "description": "Deprecated. Historically used for the codex CLI; PIKA does not read this for provider=local (Loca). Kept for backward-compatible configs."
        },
        "exec_timeout_sec": {
          "type": "integer",
          "minimum": 1,
          "description": "Timeout (seconds) for Loca agent calls when provider is local. Same key as pika.yaml local.exec_timeout_sec; overrides PIKA default for this workspace."
        },
        "default": {
          "$ref": "#/$defs/local_agent_profile",
          "description": "Workspace default local-model settings applied to all local agents unless a more specific agent override is present."
        },
        "project_designer": {
          "$ref": "#/$defs/local_agent_profile",
          "description": "Workspace override for the project_designer agent."
        },
        "design_reviewer": {
          "$ref": "#/$defs/local_agent_profile",
          "description": "Workspace override for the design_reviewer agent."
        },
        "map_spec_to_code": {
          "$ref": "#/$defs/local_agent_profile",
          "description": "Workspace override for the map_spec_to_code agent. The local prompt variant map_spec_to_code_local resolves through this key."
        },
        "implement_unified_planner": {
          "$ref": "#/$defs/local_agent_profile",
          "description": "Workspace override for the implement_unified_planner agent."
        },
        "implement_from_specs": {
          "$ref": "#/$defs/local_agent_profile",
          "description": "Workspace override for the implement_from_specs agent. The local prompt variant implement_from_specs_local resolves through this key."
        },
        "map_issues_to_specs": {
          "$ref": "#/$defs/local_agent_profile",
          "description": "Workspace override for the map_issues_to_specs agent."
        },
        "resolve_issues_with_diffs": {
          "$ref": "#/$defs/local_agent_profile",
          "description": "Workspace override for the resolve_issues_with_diffs agent."
        },
        "spec_quality_auditor": {
          "$ref": "#/$defs/local_agent_profile",
          "description": "Workspace override for the unified spec_quality_auditor agent (refine command). Replaces the deprecated spec_ambiguity_detector and spec_testability_enricher overrides."
        },
        "spec_ambiguity_detector": {
          "$ref": "#/$defs/local_agent_profile",
          "description": "DEPRECATED. Workspace override for the legacy spec_ambiguity_detector agent. Has no effect on the active refine pipeline; use spec_quality_auditor instead. Retained for backwards compatibility with existing project configs."
        },
        "spec_testability_auditor": {
          "$ref": "#/$defs/local_agent_profile",
          "description": "DEPRECATED. Workspace override for the legacy spec_testability_auditor agent. Has no effect on the active refine pipeline; use spec_quality_auditor instead. Retained for backwards compatibility with existing project configs."
        },
        "spec_editor": {
          "$ref": "#/$defs/local_agent_profile",
          "description": "Workspace override for the spec_editor agent."
        },
        "provider_sub": {
          "type": "string",
          "enum": ["openai", "openai-codex", "anthropic"],
          "description": "Loca LLM sub-provider for local agent: openai (OpenAI-compatible API key), anthropic (Anthropic Messages API + ANTHROPIC_API_KEY), or openai-codex (ChatGPT OAuth). Same key as pika.yaml local.provider_sub. Default: openai-codex."
        }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "map", "implement", "resolve_plan", "refine"],
      "properties": {
        "plan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "inputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "srs_path": { "type": "string", "minLength": 1 },
                "project_context_filename": { "type": "string", "minLength": 1 }
              }
            },
            "outputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "root_dir": { "$ref": "#/$defs/output_target" },
                "backups_dir": { "$ref": "#/$defs/output_target" },
                "agent_runs_dir": { "$ref": "#/$defs/output_target" },
                "agent_artifacts_dir": { "$ref": "#/$defs/output_target" },
                "logs_dir": { "$ref": "#/$defs/output_target" }
              }
            }
          }
        },
        "format": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "deterministic", "copy_before_write", "outputs"],
          "properties": {
            "enabled": { "type": "boolean" },
            "deterministic": { "type": "boolean", "const": true },
            "copy_before_write": { "type": "boolean", "const": true },
            "inputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "design_spec_path": { "type": "string", "minLength": 1, "description": "Source path for format. CLI --design-spec overrides; otherwise this value is used. No further fallback." }
              }
            },
            "outputs": {
              "type": "object",
              "additionalProperties": false,
              "required": ["design_spec_path"],
              "properties": {
                "design_spec_path": { "$ref": "#/$defs/output_target", "description": "Path where format writes. After writing, format copies to project.state.design_spec_path." },
                "backups_dir": { "$ref": "#/$defs/output_target", "description": "Directory for backups before overwrite when copy_before_write." }
              }
            },
            "sensitive_keywords": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "required": ["keywords"],
                "properties": {
                  "keywords": { "type": "array", "items": { "type": "string" } },
                  "case_sensitive": { "type": "boolean", "default": false }
                }
              },
              "description": "Replacement -> {keywords: [...], case_sensitive?: bool}. keywords required; case_sensitive optional (default false). Whole-word match."
            },
            "column_synonyms": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string" }
              },
              "description": "Per-logical-name synonym lists that extend the pika.yaml defaults. Keys match logical column names (e.g. sads_id, sads, unit, subunit). Matching strips -, _, whitespace and is case-insensitive."
            },
            "enrichment": {
              "type": "object",
              "additionalProperties": false,
              "description": "Optional agent phase that auto-fills module_role (per module_tag) and acceptance_criteria (per spec) after deterministic normalization.",
              "properties": {
                "enabled": { "type": "boolean", "default": false, "description": "Set true to run the design_doc_enricher agent after format normalization." },
                "skip_filled": { "type": "boolean", "default": true, "description": "Skip rows that already have non-empty module_role and acceptance_criteria." }
              }
            }
          }
        },
        "review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "inputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "design_spec_path": { "type": "string", "minLength": 1 },
                "srs_path": { "type": "string", "minLength": 1 },
                "project_context_filename": { "type": "string", "minLength": 1 }
              }
            },
            "outputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "root_dir": { "$ref": "#/$defs/output_target" },
                "backups_dir": { "$ref": "#/$defs/output_target" },
                "agent_runs_dir": { "$ref": "#/$defs/output_target" },
                "agent_artifacts_dir": { "$ref": "#/$defs/output_target" },
                "logs_dir": { "$ref": "#/$defs/output_target" }
              }
            }
          }
        },
        "map": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "inputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "design_spec_path": { "type": "string", "minLength": 1 },
                "codebase_dir": { "type": "string", "minLength": 1 },
                "project_context_filename": { "type": "string", "minLength": 1 },
                "extra_prompt_filename": { "type": "string", "minLength": 1 }
              }
            },
            "outputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "root_dir": { "$ref": "#/$defs/output_target" },
                "backups_dir": { "$ref": "#/$defs/output_target" },
                "agent_runs_dir": { "$ref": "#/$defs/output_target" },
                "agent_artifacts_dir": { "$ref": "#/$defs/output_target" },
                "logs_dir": { "$ref": "#/$defs/output_target" },
                "agent_view_csv": { "$ref": "#/$defs/output_target" },
                "intermediate_map_dir": { "$ref": "#/$defs/output_target" },
                "agent_input_codebase_content_dir": { "$ref": "#/$defs/output_target" }
              }
            },
            "skip_mapped": {
              "type": "boolean",
              "description": "Skip map_status=mapped on re-runs. Default true."
            },
            "max_acceptance_chars": {
              "type": "integer",
              "minimum": 0,
              "description": "Truncate acceptance_criteria at invocation (0 = unlimited)."
            },
            "max_specs_per_subunit": {
              "type": "integer",
              "minimum": 1,
              "description": "Max rows per subunit agent call. Larger subunits are split into consecutive sub-batches."
            },
            "min_remapping_confidence_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Re-map 'mapped' rows whose max confidence falls below this threshold. Default 0.0 (disabled)."
            },
            "max_problem_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Inject into prompt: agents must only populate problems when confidence OR consistency_score < threshold. Default 1.0."
            }
          }
        },
        "implement": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "inputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "design_spec_path": { "type": "string", "minLength": 1 },
                "codebase_dir": { "type": "string", "minLength": 1 },
                "project_context_filename": { "type": "string", "minLength": 1 },
                "issue_tracker_path": { "type": "string", "minLength": 1 },
                "appendices": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/appendix_item" },
                  "description": "Appendix documents provided alongside the design spec."
                }
              }
            },
            "appendix": { "$ref": "#/$defs/appendix_settings" },
            "outputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "root_dir": { "$ref": "#/$defs/output_target" },
                "backups_dir": { "$ref": "#/$defs/output_target" },
                "agent_runs_dir": { "$ref": "#/$defs/output_target" },
                "agent_artifacts_dir": { "$ref": "#/$defs/output_target" },
                "logs_dir": { "$ref": "#/$defs/output_target" },
                "agent_input_codebase_content_dir": { "$ref": "#/$defs/output_target" }
              }
            },
            "unified_planner": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "disallowed_link_kinds_by_required_role": {
                  "$ref": "#/properties/commands/properties/implement/properties/disallowed_link_kinds_by_required_role"
                },
                "leaf_dependency_roles": {
                  "$ref": "#/properties/commands/properties/implement/properties/leaf_dependency_roles"
                },
                "leaf_dependency_policy": {
                  "$ref": "#/properties/commands/properties/implement/properties/leaf_dependency_policy"
                },
                "contract_kind_definitions": {
                  "$ref": "#/properties/commands/properties/implement/properties/contract_kind_definitions"
                },
                "type_shape_match": {
                  "$ref": "#/properties/commands/properties/implement/properties/type_shape_match"
                },
                "min_confidence_threshold": {
                  "$ref": "#/properties/commands/properties/implement/properties/min_confidence_threshold"
                }
              }
            },
            "workset_schema_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "module_catalog_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "planner_path_contract_prep": { "$ref": "#/$defs/implement_step_toggle" },
            "planner_semantic_validation": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "semantic_validation_retries": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Step-level retries for planner semantic validation."
                }
              }
            },
            "planner_manual_resolution_gate": { "$ref": "#/$defs/implement_step_toggle" },
            "spec_issue_escalation": { "$ref": "#/$defs/implement_step_toggle" },
            "unified_plan_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "contract_field_consistency_validation": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "field_match_score_threshold": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Step-level normalized similarity threshold (0..1) for contract/spec high-match pairs."
                }
              }
            },
            "required_field_coverage_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "batch_plan_construction": { "$ref": "#/$defs/implement_step_toggle" },
            "batch_plan_dependency_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "batch_brief_build": { "$ref": "#/$defs/implement_step_toggle" },
            "batch_brief_scope_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "dependency_context_edge_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "batch_runtime_path_contract_prep": { "$ref": "#/$defs/implement_step_toggle" },
            "implement_semantic_validation": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "semantic_validation_retries": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Step-level retries for implement output semantic validation."
                }
              }
            },
            "implement_output_structure_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "patch_constraints_validation": { "$ref": "#/$defs/implement_step_toggle" },
            "verification_command_resolution": { "$ref": "#/$defs/implement_step_toggle" },
            "patch_normalization": { "$ref": "#/$defs/implement_step_toggle" },
            "patch_apply_gate": { "$ref": "#/$defs/implement_step_toggle" },
            "contract_schema_conformance_check": { "$ref": "#/$defs/implement_step_toggle" },
            "verification_execution": { "$ref": "#/$defs/implement_step_toggle" },
            "type_placement_path": {
              "type": "string",
              "minLength": 1,
              "description": "Path prefix for cross-module shared type locations."
            },
            "allowed_module_roles": {
              "type": "array",
              "items": { "type": "string", "enum": ["frontend", "api", "domain", "infra", "shared", "cli", "worker"] },
              "description": "Allowed module_role values for implement validation."
            },
            "disallowed_link_kinds_by_required_role": {
              "type": "object",
              "additionalProperties": false,
              "description": "Role-based contract kinds disallowed on required bindings during implement link-plan validation.",
              "properties": {
                "frontend": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"] }
                },
                "api": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"] }
                },
                "domain": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"] }
                },
                "infra": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"] }
                },
                "shared": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"] }
                },
                "cli": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"] }
                },
                "worker": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["api_endpoint", "service_interface", "event_topic", "db_table", "file_format", "external_api", "test_suite"] }
                }
              }
            },
            "leaf_dependency_roles": {
              "type": "array",
              "items": { "type": "string", "enum": ["frontend", "api", "domain", "infra", "shared", "cli", "worker"] },
              "description": "Module roles treated as leaf dependencies. For these roles, required_intents are auto-dropped during normalization."
            },
            "leaf_dependency_policy": {
              "type": "object",
              "additionalProperties": false,
              "description": "Deterministic policy for leaf dependency enforcement.",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": ["auto_drop"],
                  "description": "Leaf dependency handling mode. Currently only auto_drop is supported."
                },
                "track_external_dependencies": {
                  "type": "boolean",
                  "description": "When true, dropped leaf required_intents are preserved as declared_external_dependencies."
                }
              }
            },
            "contract_kind_definitions": {
              "type": "object",
              "additionalProperties": false,
              "description": "Canonical semantic definitions for contract kinds, injected into planner prompts.",
              "properties": {
                "api_endpoint": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["definition"],
                  "properties": { "definition": { "type": "string", "minLength": 1 } }
                },
                "service_interface": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["definition"],
                  "properties": { "definition": { "type": "string", "minLength": 1 } }
                },
                "event_topic": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["definition"],
                  "properties": { "definition": { "type": "string", "minLength": 1 } }
                },
                "db_table": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["definition"],
                  "properties": { "definition": { "type": "string", "minLength": 1 } }
                },
                "file_format": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["definition"],
                  "properties": { "definition": { "type": "string", "minLength": 1 } }
                },
                "external_api": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["definition"],
                  "properties": { "definition": { "type": "string", "minLength": 1 } }
                },
                "test_suite": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["definition"],
                  "properties": { "definition": { "type": "string", "minLength": 1 } }
                }
              }
            },
            "type_shape_match": {
              "type": "object",
              "additionalProperties": false,
              "description": "Deterministic thresholds for normalized required->provided candidate scoring.",
              "properties": {
                "min_auto_bind_score": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Minimum top candidate score to mark auto_bind_candidate in normalized intent catalog."
                },
                "tie_margin": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Required score margin between top-1 and top-2 candidate for auto_bind_candidate."
                }
              }
            },
            "issue_tracker_path": {
              "type": "string",
              "minLength": 1,
              "description": "Path to implementation issue tracker CSV for verification failures."
            },
            "test_spec_path": {
              "type": "string",
              "minLength": 1,
              "description": "Path to test_spec CSV generated/updated by implement."
            },
            "verification_commands": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "description": "Commands run after patch application for batch verification."
            },
            "forbidden_paths": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "description": "Relative path prefixes disallowed for implement diffs."
            },
            "budgets": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "max_specs_per_batch": { "type": "integer", "minimum": 1 },
                "max_files": { "type": "integer", "minimum": 1 },
                "max_lines_changed": { "type": "integer", "minimum": 1 },
                "max_context_tokens": { "type": "integer", "minimum": 1 }
              }
            },
            "min_confidence_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "During batch briefs planning, items with confidence below this value are appended to manual_resolution_items and block downstream code generation until resolved. Project config overrides pika config (default 0.7). Set to 0 to disable."
            },
            "evaluator": {
              "type": "object",
              "additionalProperties": false,
              "description": "Code evaluator sub-agent run after batch execution. Scores applied diffs against per-spec acceptance_criteria and consumes deterministic harness gate results.",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "When true, run the code_evaluator stage after batch execution. Default false."
                },
                "max_eval_cycles": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Maximum number of evaluator re-run cycles after the initial pass. 0 disables re-runs. Default 1."
                },
                "fail_action": {
                  "type": "string",
                  "enum": ["block", "warn"],
                  "description": "Action when evaluator returns passed=false after exhausting cycles. block writes manual_resolution; warn logs and continues. Default warn."
                },
                "rerun_severity_threshold": {
                  "type": "string",
                  "enum": ["major", "blocker"],
                  "description": "Minimum severity for failed_specs entries to trigger a targeted batch re-run. Default blocker."
                },
                "harnesses": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "syntax_check",
                      "import_smoke",
                      "unresolved_symbol",
                      "forbidden_path_violation",
                      "anchor_preservation",
                      "diff_size_sanity"
                    ]
                  },
                  "description": "Deterministic harness gates to run before each evaluator invocation. Default: all six."
                },
                "diff_size_sanity_max_lines": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Threshold above which a single spec-attributed diff is flagged as runaway by diff_size_sanity. Default 2000."
                }
              }
            }
          }
        },
        "resolve_plan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "inputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "design_spec_path": { "type": "string", "minLength": 1 },
                "issue_tracking_path": { "type": "string", "minLength": 1 }
              }
            },
            "outputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "root_dir": { "$ref": "#/$defs/output_target" },
                "backups_dir": { "$ref": "#/$defs/output_target" },
                "agent_runs_dir": { "$ref": "#/$defs/output_target" },
                "agent_artifacts_dir": { "$ref": "#/$defs/output_target" },
                "logs_dir": { "$ref": "#/$defs/output_target" }
              }
            }
          }
        },
        "refine": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "decomposition", "inputs", "outputs"],
          "properties": {
            "enabled": { "type": "boolean" },
            "decomposition": {
              "type": "object",
              "additionalProperties": false,
              "required": ["enabled", "blocking", "similarity_threshold", "variance_threshold"],
              "properties": {
                "enabled": { "type": "boolean" },
                "blocking": { "type": "boolean" },
                "similarity_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
                "variance_threshold": { "type": "number", "minimum": 0 }
              }
            },
            "inputs": {
              "type": "object",
              "additionalProperties": false,
              "required": ["design_spec_path", "project_context_filename"],
              "properties": {
                "design_spec_path": { "type": "string", "minLength": 1 },
                "project_context_filename": { "type": "string", "minLength": 1 },
                "appendices": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/appendix_item" },
                  "description": "Appendix documents provided alongside the design spec."
                }
              }
            },
            "appendix": { "$ref": "#/$defs/appendix_settings" },
            "agent_replicas": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of parallel ambiguity-detector and testability-auditor agent instances each (same N for both)."
            },
            "consensus_min_votes": {
              "type": "integer",
              "minimum": 1,
              "description": "Minimum cross-instance votes required to keep a flagged spec_id after consensus filtering; runtime clamps to agent_replicas."
            },
            "outputs": {
              "type": "object",
              "additionalProperties": false,
              "required": ["root_dir", "design_spec_path", "agent_runs_dir"],
              "properties": {
                "root_dir": { "$ref": "#/$defs/output_target" },
                "design_spec_path": { "$ref": "#/$defs/output_target" },
                "agent_runs_dir": { "$ref": "#/$defs/output_target" }
              }
            }
          }
        }
      }
    },
    "id_generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id_registry"],
      "properties": {
        "id_registry": {
          "type": "string",
          "minLength": 1,
          "description": "Primary path for id_registry.json during format (before optional copy to project.state.id_registry_path). Same key as pika.yaml default_outputs.id_registry; overrides PIKA default when set."
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "verbose_level", "json"],
      "properties": {
        "level": { "type": "string", "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"] },
        "verbose_level": { "type": "string", "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"] },
        "json": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "implement_step_toggle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "local_agent_profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Model ID for this local agent profile (for example gpt-5.3-codex)."
        },
        "reasoning_effort": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["low", "medium", "high", "xhigh"],
              "description": "Loca model_reasoning_effort for reasoning models."
            },
            {
              "type": "null",
              "description": "Omit reasoning effort so Loca can apply temperature/top_p (see Loca ModelConfig)."
            }
          ],
          "description": "Loca model_reasoning_effort, or null to disable for sampling params."
        },
        "model_verbosity": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ],
          "description": "Optional model_verbosity override for this agent profile. Null clears any inherited value."
        },
        "web_search": {
          "type": "boolean",
          "description": "Whether web search is enabled for this agent profile."
        },
        "temperature": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature for this agent profile. Null means provider default."
        },
        "top_p": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "Nucleus sampling probability for this agent profile. Null means provider default."
        }
      }
    },
    "output_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "no_overwrite"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "no_overwrite": { "type": "boolean" }
      }
    },
    "appendix_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "description": "Path to appendix file (relative to project root)." },
        "format": { "type": "string", "enum": ["text", "csv"], "default": "text", "description": "File format: text (one file = one entry) or csv (one row = one entry)." },
        "module_tag": { "type": "string", "minLength": 1, "description": "Module scope. Omit for general appendix (all modules)." },
        "title": { "type": "string", "minLength": 1, "description": "Display title (text format only; CSV rows use their own title column)." }
      }
    },
    "appendix_settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_appendix_chars": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Max total chars for appendix content injected into prompts. 0 = no limit. Exceeding triggers preflight error."
        }
      }
    }
  }
}
